---
import Footer9 from "../components/starwind-pro/footer-09/Footer9.astro";
import "../styles/starwind.css";
const title = "gwilym.ca";
---
<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/dragon.svg" />
    <meta name="robots" content="noindex" />
  </head>
  <body class="bg-background text-foreground min-h-screen flex flex-col">
    <main class="flex-1 grid place-items-center pb-[12rem]">
      <picture>
        <source srcset="/dragon.webp" type="image/webp" />
        <img src="/dragon.png" alt="" class="block h-auto max-w-[min(60vw,60vh)]" />
      </picture>
    </main>
    <Footer9
      largeText="GWILYM"
      columns={[]}
      socialLinks={[]}
      class="pt-0 fixed bottom-0 left-0 right-0"
    />
  </body>
</html>
